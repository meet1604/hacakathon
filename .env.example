# ─── AI Provider ───────────────────────────────────────────────────────────────
# Switch between providers by changing only this one line:
#   development  →  openrouter   (free Qwen model)
#   production   →  anthropic    (Claude Sonnet)
AI_PROVIDER=openrouter

# ─── Anthropic (production) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenRouter (development / free tier) ───────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-
# Default model if not set: qwen/qwen3-6b-instruct:free
# To use Qwen 3.6 Plus Preview set it explicitly:
OPENROUTER_MODEL=

# ─── Supabase ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
