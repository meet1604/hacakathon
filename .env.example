# ─── AI Provider ────────────────────────────────────────────────────────────────
# Switch between providers by changing only this one line:
#   openrouter  →  free tier (Qwen)
#   anthropic   →  Claude (production)
#   gemini      →  Google Gemini
#   groq        →  Groq (Llama)
#   nvidia      →  NVIDIA NIM
AI_PROVIDER=gemini

# ─── Anthropic ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Default: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── OpenRouter ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Default: qwen/qwen3-6b-instruct:free
OPENROUTER_MODEL=qwen/qwen3-6b-instruct:free
# Default: https://openrouter.ai/api/v1/chat/completions
OPENROUTER_BASE=https://openrouter.ai/api/v1/chat/completions

# ─── Google Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Default: https://generativelanguage.googleapis.com/v1beta
GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta

# ─── Groq ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
# Default: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
# Default: https://api.groq.com/openai/v1/chat/completions
GROQ_BASE=https://api.groq.com/openai/v1/chat/completions

# ─── NVIDIA NIM ──────────────────────────────────────────────────────────────────
NVIDIA_NIM_API_KEY=nvapi-...
# Default: meta/llama-3.1-405b-instruct
NVIDIA_MODEL=meta/llama-3.1-405b-instruct
# Default: https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_BASE=https://integrate.api.nvidia.com/v1/chat/completions

# ─── Supabase ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
